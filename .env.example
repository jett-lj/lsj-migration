# ── Target PostgreSQL database ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=lsj_admin
DB_PASSWORD=__set_me__
DB_NAME=barmount

# Or use a full connection string instead:
# PG_CONNECTION_STRING=postgres://lsj_admin:__set_me__@localhost:5432/barmount

# ── Legacy SQL Server (migration source) ─────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=lsj_migrate
MSSQL_PASSWORD=__set_me__
MSSQL_DATABASE=CATTLE

# ── Migration options ────────────────────────────────
MIGRATION_BATCH_SIZE=500
MIGRATION_LOG_LEVEL=info
